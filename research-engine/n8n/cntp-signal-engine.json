      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse Gemini Response (Tier 2) — Run Once for EACH Item\nconst _extractJson = (raw) => {\n  if (raw == null) return null;\n  let s = raw.toString().trim().replace(/^```(?:json)?/i,'').replace(/```$/,'').trim();\n  const a = s.indexOf('{'), b = s.lastIndexOf('}');\n  if (a === -1 || b === -1 || b < a) return null;\n  const c = s.slice(a, b + 1);\n  try { return JSON.parse(c); }\n  catch (e) { try { return JSON.parse(c.replace(/,\\s*([}\\]])/g,'$1')); } catch (e2) { return null; } }\n};\nconst _findText = (o, d = 0) => {\n  if (o == null || d > 6) return null;\n  if (typeof o === 'string') return o.includes('{') ? o : null;\n  if (Array.isArray(o)) { for (const v of o) { const r = _findText(v, d+1); if (r) return r; } return null; }\n  if (typeof o === 'object') {\n    for (const k of ['text','output_text','content','response']) {\n      if (typeof o[k] === 'string' && o[k].includes('{')) return o[k];\n    }\n    for (const k in o) { const r = _findText(o[k], d+1); if (r) return r; }\n  }\n  return null;\n};\nconst ALLOWED = ['opportunity','threat','competitor','regulation','relationship','neutral'];\nconst CLASS_MAP = { loophole:'opportunity', market_gap:'opportunity', switching_signal:'opportunity',\n  emerging_trend:'opportunity', relationship_signal:'relationship', competitor_intel:'competitor',\n  competitor:'competitor', threat:'threat', neutral:'neutral' };\nconst toClass = (t, fallback) => ALLOWED.includes(t) ? t : (CLASS_MAP[t] || CLASS_MAP[fallback] || 'neutral');\nconst g = $json;\nconst base = $('Score Filter').item.json;\nconst p = _extractJson(_findText(g) || '') || {};\nreturn { json: {\n  title: base.title || '',\n  source_domain: base.source?.url ?? '',\n  source_url: base.link || '',\n  source_type: 'news',\n  raw_content: (base.description || '').slice(0, 2000),\n  language: p.language || 'en',\n  region: p.region || base.ollama_region || 'GLOBAL',\n  classification: toClass(p.classification, base.ollama_intelligence_type),\n  relevance_score: Number(p.relevance_score ?? base.ollama_relevance_score) || 0,\n  summary_en: p.summary_en || base.ollama_summary || '',\n  keyword_group: p.keyword_group || base.ollama_keyword_group || 'general',\n  sales_angle: p.sales_angle || base.ollama_sales_angle || '',\n  urgency: p.urgency || base.ollama_urgency || 'low',\n  tier: 2,\n  sections: [],\n  intel: { ...p, intelligence_type: base.ollama_intelligence_type || p.classification || 'neutral' },\n} };"
