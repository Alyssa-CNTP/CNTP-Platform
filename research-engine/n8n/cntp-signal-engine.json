    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse Tier 1 (Gemini) — Run Once for EACH Item\n// Robust against the googleGemini node's varying output nesting.\nconst _extractJson = (raw) => {\n  if (raw == null) return null;\n  let s = raw.toString().trim().replace(/^```(?:json)?/i,'').replace(/```$/,'').trim();\n  const a = s.indexOf('{'), b = s.lastIndexOf('}');\n  if (a === -1 || b === -1 || b < a) return null;\n  const c = s.slice(a, b + 1);\n  try { return JSON.parse(c); }\n  catch (e) { try { return JSON.parse(c.replace(/,\\s*([}\\]])/g,'$1')); } catch (e2) { return null; } }\n};\n// Deep-scan the node output for the first string that looks like JSON.\nconst _findText = (o, d = 0) => {\n  if (o == null || d > 6) return null;\n  if (typeof o === 'string') return o.includes('{') ? o : null;\n  if (Array.isArray(o)) { for (const v of o) { const r = _findText(v, d+1); if (r) return r; } return null; }\n  if (typeof o === 'object') {\n    for (const k of ['text','output_text','content','response']) {\n      if (typeof o[k] === 'string' && o[k].includes('{')) return o[k];\n    }\n    for (const k in o) { const r = _findText(o[k], d+1); if (r) return r; }\n  }\n  return null;\n};\nconst g = $json;\nconst base = $('Dedup Check').item.json;          // original article (paired)\nconst text = _findText(g) || '';\nconst p = _extractJson(text) || {};\nreturn { json: {\n  title: base.title || '',\n  link: base.link || '',\n  description: base.description || '',\n  clean_description: base.clean_description || '',\n  source: base.source || {},\n  ollama_summary: p.summary || '',\n  ollama_intelligence_type: p.intelligence_type || 'neutral',\n  ollama_sales_angle: p.sales_angle || '',\n  ollama_relevance_score: Number(p.relevance_score) || 0,\n  ollama_urgency: p.urgency || 'low',\n  ollama_region: p.region || 'GLOBAL',\n  ollama_segment: p.target_segment || 'unknown',\n  ollama_competitor: p.competitor_mentioned || null,\n  ollama_keyword_group: p.keyword_group || 'general',\n  _raw: (text || JSON.stringify(g)).slice(0, 400),   // debug: what Gemini returned\n} };"
      },
