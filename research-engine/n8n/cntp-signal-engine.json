    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  const cleanDesc = (item.json.description || '')\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .slice(0, 400);\n\n  items.push({\n    json: {\n      ...item.json,\n      clean_description: cleanDesc\n    }\n  });\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5152,
        -416
      ],
      "id": "85d2ec98-f03b-4aa4-bfb6-fa064a9bcb06",
      "name": "Pre-Processing1"
    },
    {
      "parameters": {
        "jsCode": "// Dedup Check — Run Once for All Items\n// Input = existing rows from \"Get Existing Titles\"; articles pulled from Pre-Processing1.\nconst norm = (t) => (t || '').toString().slice(0, 100).trim().toLowerCase();\n\nconst existing = new Set();\nfor (const r of $input.all()) {\n  const k = norm(r.json.title);\n  if (k) existing.add(k);\n}\n\nconst seen = new Set();\nconst out = [];\nfor (const item of $('Pre-Processing1').all()) {\n  const key = norm(item.json.title);\n  if (!key) continue;                  // no title\n  if (existing.has(key)) continue;     // already stored\n  if (seen.has(key)) continue;         // duplicate within this run\n  seen.add(key);\n  out.push({ json: item.json });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
