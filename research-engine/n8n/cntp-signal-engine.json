        "messages": {
          "values": [
            {
              "content": "=You are a senior market intelligence analyst for Cape Natural Tea Products (CNTP), a South African rooibos tea exporter. A first-pass AI has identified this as a high-relevance signal (score: {{ $json.ollama_relevance_score }}/10).\n\nProvide deep strategic analysis.\n\nTitle: {{ $json.title }}\nInitial classification: {{ $json.ollama_intelligence_type }}\nInitial sales angle: {{ $json.ollama_sales_angle }}\nRegion: {{ $json.ollama_region }}\nContent: {{ $json.clean_description }}\n\nRespond ONLY with valid JSON, no markdown:\n{\n  \"summary_en\": \"2-3 sentences: what this means strategically for CNTP and what action it suggests\",\n  \"classification\": \"opportunity|threat|competitor|regulation|relationship|neutral\",\n  \"relevance_score\": 1,\n  \"region\": \"ISO country code or GLOBAL\",\n  \"language\": \"2-letter language code\",\n  \"keyword_group\": \"core_product|competitor|negative_signal|wellness|trade|creative|general\",\n  \"sales_angle\": \"Specific recommended action for the CNTP sales team\",\n  \"urgency\": \"low|medium|high\"\n}"
            }
          ]
        },
        "builtInTools": {},
